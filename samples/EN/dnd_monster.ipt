Header: <b>D&D Monster Generator</b>
Footer: <hr><i>Roll for initiative!</i>

Table: monster
Set: mtype = [@monster_type]
Set: mname = [@name_{mtype}]
Set: cr = [@challenge_rating]
<b>MONSTER STAT BLOCK</b>\n&
Name:        <b>{mname}</b>\n&
Type:        {mtype}\n&
Size:        [@size]\n&
Alignment:   [@alignment]\n&
CR:          {cr}\n&
\n&
<b>STATISTICS</b>\n&
AC: {1d4 + 10}   HP: {2d8 + 10} ({1d4 + 3}d8 + {1d6})   Speed: {1d4 * 10} ft\n&
STR [{2d6 + 4} >> +-]  DEX [{2d6 + 2} >> +-]  CON [{2d6 + 3} >> +-]\n&
INT [{2d6} >> +-]  WIS [{2d6 + 1} >> +-]  CHA [{2d6} >> +-]\n&
\n&
<b>DEFENCES</b>\n&
[@defences_{mtype}]\n&
Senses: [@senses_{mtype}]\n&
Languages: [@languages_{mtype}]\n&
\n&
<b>TRAITS</b>\n&
[!1 trait_{mtype}]\n&
[!1 trait_{mtype}]\n&
[!1 trait_{mtype}]\n&
\n&
<b>ACTIONS</b>\n&
[!1 action_{mtype}]\n&
[!1 action_{mtype}]\n&
\n&
<b>BONUS ACTION / REACTION</b>\n&
[@bonus_{mtype}]\n&
\n&
<b>LAIR & BEHAVIOUR</b>\n&
Lair:      [@lair]\n&
Behaviour: [!1 behaviour]\n&
\n&
<b>TREASURE</b>\n&
[@treasure_{mtype}]

