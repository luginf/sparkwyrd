// ----------------------------------------------------------------
// Appearance by race
// ----------------------------------------------------------------

Table: appearance_Human
Hair: [@hair_human], Eyes: [@eyes], Build: [@build], Height: {1d10 + 163} cm
Skin: [@skin_human]. Distinguishing feature: [@feature]

Table: appearance_Elf
Hair: [@hair_elf], Eyes: [@eyes_elf], Build: [|slender|willowy|graceful], Height: {1d8 + 168} cm
Ears: [|slightly|noticeably|dramatically] pointed. Skin: [@skin_elf]. Feature: [@feature]

Table: appearance_Dwarf
Hair: [@hair_dwarf], Eyes: [@eyes], Build: [|stocky|barrel-chested|broad-shouldered|compact], Height: {1d6 + 134} cm
Beard: [@beard_dwarf]. Skin: [@skin_human]. Feature: [@feature]

Table: appearance_Half-Orc
Hair: [@hair_human], Eyes: [|grey|pale yellow|deep brown|reddish|amber], Build: [|muscular|imposing|powerfully built|bulky], Height: {1d10 + 172} cm
Tusks: [|small|prominent|filed down|cracked|decorated with rings]. Skin: [|grey-green|olive|dark grey|pale green]. Feature: [@feature]

Table: appearance_Halfling
Hair: [@hair_human], Eyes: [@eyes], Build: [|small and nimble|compact|round-faced|cheerful-looking], Height: {1d4 + 83} cm
Feet: [|large and hairy|unusually tidy|callused from travel]. Skin: [@skin_human]. Feature: [@feature]

Table: appearance_Gnome
Hair: [@hair_gnome], Eyes: [|bright blue|vivid green|amber|violet|deep brown], Build: [|small|wiry|bouncy], Height: {1d4 + 92} cm
Skin: [@skin_gnome]. Feature: [@feature]

Table: appearance_Tiefling
Hair: [@hair_tiefling], Eyes: [|solid black|solid white|glowing red|deep violet|amber without pupil], Build: [@build], Height: {1d8 + 163} cm
Horns: [|small curved|long swept-back|spiralling|stubbed|asymmetrical]. Tail: [|thin whip-like|thick leonine|absent]. Skin: [|deep red|dark purple|dusky blue|pale grey]. Feature: [@feature]

Table: appearance_Dragonborn
Hair: none — [|smooth scales cover the scalp|small crest of scales|vestigial frills], Eyes: [@eyes_elf], Build: [|tall and muscular|broad|imposing|lean], Height: {1d10 + 178} cm
Scale colour: [|red|gold|silver|black|blue|green|bronze|copper|white|brass]. Feature: [@feature]

Table: appearance_Half-Elf
Hair: [@hair_human], Eyes: [|bright green|light grey|violet|hazel|one brown one blue], Build: [@build], Height: {1d8 + 163} cm
Ears: slightly tapered. Skin: [@skin_elf]. Feature: [@feature]

Table: appearance_Aasimar
Hair: [@hair_aasimar], Eyes: [|solid silver|solid gold|pale blue|glowing white], Build: [@build], Height: {1d8 + 165} cm
Skin: [@skin_aasimar]. Halo: [|faint and invisible in daylight|visible in darkness|a warm golden shimmer when emotions run high|absent unless using divine power]. Feature: [@feature]

