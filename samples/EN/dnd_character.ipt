Header: <b>D&D Character Generator</b>
Footer: <hr><i>May the dice be ever in your favour.</i>

Table: character
Set: race = [@race]
Set: class = [@class]
Set: bg = [@background]
Set: name = [@firstname_[@race]] [@surname]
<b>CHARACTER SHEET</b>\n&
Name:       <b>{name}</b>\n&
Race:       {race}\n&
Class:      {class}\n&
Level:      {1d6 + 1}\n&
Background: {bg}\n&
\n&
<b>APPEARANCE</b>\n&
[@appearance_{race}]\n&
\n&
<b>ABILITY SCORES</b>\n&
STR [{3d6} >> +-]  DEX [{3d6} >> +-]  CON [{3d6} >> +-]\n&
INT [{3d6} >> +-]  WIS [{3d6} >> +-]  CHA [{3d6} >> +-]\n&
\n&
<b>PROFICIENCIES</b>\n&
Skills:    [@skills_{bg}]\n&
Languages: [@languages_{race}]\n&
\n&
<b>RACIAL ABILITY</b>\n&
[@racial_{race}]\n&
\n&
<b>TRAITS</b>\n&
Personality: [!1 personality]\n&
Ideal:       [!1 ideal]\n&
Bond:        [!1 bond]\n&
Flaw:        [!1 flaw]\n&
\n&
<b>EQUIPMENT</b>\n&
[@equipment_{class}]\n&
Starting gold: {2d6 * 5} gp\n&
\n&
<b>BACKSTORY HOOK</b>\n&
[@backstory]

